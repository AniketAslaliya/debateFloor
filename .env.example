# Copy this file to .env and customize as needed for local inference runs.

# Required by the Round-1 evaluation harness.
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
HF_TOKEN=replace_with_your_hf_or_router_token

# Optional compatibility override if a local LiteLLM/OpenAI-compatible proxy injects API_KEY.
API_KEY=
